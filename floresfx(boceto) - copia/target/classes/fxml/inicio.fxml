<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="application.controllers.InicioController"
            stylesheets="@/styles/styles.css"
            style="-fx-background-image: url('/images/inicio.png');
                   -fx-background-size: cover;
                   -fx-background-position: center center;
                   -fx-background-repeat: no-repeat;">

    <center>
        <HBox alignment="CENTER"
              spacing="40">

            <padding>
                <Insets top="40" right="40" bottom="40" left="40"/>
            </padding>

            <!-- TEXTO -->
            <VBox alignment="CENTER_LEFT"
                  spacing="15"
                  maxWidth="380">

                <Label text="Creaciones Eternas"
                       styleClass="titulo"/>

                <Label text="Flores que no se marchitan, recuerdos que perduran"
                       wrapText="true"
                       styleClass="frase"/>

                <Label text="Arreglos florales preservados creados para acompañar tus momentos más especiales."
                       wrapText="true"
                       styleClass="frase"/>

                <Button text="Ver Catálogo"
                        onAction="#irCatalogo"
                        styleClass="boton-principal"/>
            </VBox>

            <!-- LOGO (ANTES ERA inicio.png) -->
            <VBox alignment="CENTER">
                <ImageView fitWidth="260"
                           preserveRatio="true">
                    <image>
                        <Image url="@/images/logo.jpeg"/>
                    </image>
                </ImageView>
            </VBox>

        </HBox>
    </center>

</BorderPane>
